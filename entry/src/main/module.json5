{
  "module": {
    "name": "entry",
    "type": "entry",
    "description": "$string:module_desc",
    "mainElement": "EntryAbility",
    "deviceTypes": [
      "phone"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
    "requestPermissions": [
      {
        "name": "ohos.permission.VIBRATE", //震动
        //"reason": "$string:review_cfm_btn_review_all"
      },
      {
        "name": "ohos.permission.GET_NETWORK_INFO" //网络状态
      },
      {
        "name": "ohos.permission.INTERNET", // 权限名称 访问网络
        //        "reason": "$string:init_tab_create", // 可选：权限申请理由（用户授权权限需填写）
        //        "usedScene": {                       // 可选：权限使用场景
        //          "abilities": ["MainAbility"],      // 使用权限的Ability列表
        //          "when": "inuse"                    // 使用时机（inuse/always）
        //        },
      },
      {
        "name": "ohos.permission.GET_BUNDLE_INFO"  //获取应用版本信息
      },

      {
        "name": "ohos.permission.PUBLISH_AGENT_REMINDER",
        "reason": "$string:set_msg_permission_notification", // 权限用途说明
        "usedScene": {
          "abilities": ["EntryAbility"], // 使用该权限的Ability
          "when": "always" // 使用时机
        }
      },
      //      {
      //        "name": "ohos.permission.FILE_ACCESS_PERSIST",
      //        "reason": "$string:shouxie_permit_file_save" //用于手写数据存储
      //      },
      {
        "name": "ohos.permission.MICROPHONE",
        "reason": "$string:microphone_permission_reason", ///用于语音识别
        "usedScene": {
          "abilities": ["EntryAbility"],
          "when": "inuse"
        }
      },
//      {
//        "name": "ohos.permission.READ_MEDIA",
//        "reason": "$string:image_read_permission_reason",//"需要读取相册权限"
//        "usedScene": {
//          "abilities": ["EntryAbility"], // 使用该权限的Ability
//          "when": "inuse" // 使用时机
//        }
//      },
//      {
//        "name": "ohos.permission.WRITE_MEDIA",
//        "reason": "$string:image_write_permission_reason",//保存字卡到相册
//        "usedScene": {
//          "abilities": ["EntryAbility"], // 使用该权限的Ability
//          "when": "inuse" // 使用时机
//        }
//      },
//      {
//        "name": "ohos.permission.CAMERA",
//        "reason": "$string:camera_permission_reason", //使用相机扫描字卡
//        "usedScene": {
//          "abilities": ["EntryAbility"], // 使用该权限的Ability
//          "when": "inuse" // 使用时机
//        }
//      },
//      {
//        "name":"ohos.permission.PRINT", //打印
//      },
      //      {
      //        "name": "ohos.permission.APP_TRACKING_CONSENT",
      //        "reason": "$string:reason",
      //        "usedScene": {}
      //      }


    ],
    "abilities": [
      {
        "name": "EntryAbility",
        "srcEntry": "./ets/entryability/EntryAbility.ets",
        "description": "$string:EntryAbility_desc",
        "icon": "$media:layered_image",
        "label": "$string:app_name",
        "startWindowIcon": "$media:startIcon",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        "skills": [
          {
            // 桌面 + QQ；单独一条 skill，避免 domainVerify 与本段 https 参与下面 FileOpen 的 Want 匹配
            "entities": [
              "entity.system.home",                      // 桌面
              "entity.system.browsable"                  // Deep Link、QQ
            ],
            "actions": [
              "action.system.home",                      // 桌面入口
              "ohos.want.action.viewData"                // QQ 等 viewData
            ],
            "uris": [
              {
                "scheme": "qqopenapi",                    // QQ 互联
                "host": "1105391403",
                "pathRegex": "\\b(auth|share)\\b",
                "linkFeature": "Login"                    // 与开放平台 appId 一致
              },
              {
                "scheme": "https",                        // AppLink
                "host": "www.dancishu.com",
                "path": "path1"                           // 按 QQ 开放平台填写
              }
            ],
            "domainVerify": true                          // 仅对本段 https 校验域名
          },
          {
            // ---------- .wte / 电子书「其他应用打开」（须配合 utd.json5；说明见下，utd 文件内禁止注释）----------
            // ① UTD 声明文件：entry/src/main/resources/rawfile/arkdata/utd/utd.json5（无扩展名的 utd 包）
            // ② 其中 TypeId（如 com.ou.hm.wordtree.ebook）必须与本段 uris[].type 中自定义类型字符串完全一致。
            // ③ FilenameExtensions、MIMETypes、BelongingToTypes 与该类型一致；改后需卸载重装才会重新注册 UTD。
            // ④ 关键：utd.json5 内不得出现任何 // 或块注释。若含注释，系统无法正确注册类型，应用不会出现在「使用其他应用打开」列表。
            // ⑤ 目标方能力见《拉起文件处理类应用》：
            //    https://developer.huawei.com/consumer/cn/doc/harmonyos-guides/file-processing-apps-startup
            //    action 固定 ohos.want.action.viewData；scheme+type+linkFeature=FileOpen（大小写敏感）。
            "actions": [
              "ohos.want.action.viewData"                // 打开文件场景固定 action
            ],
            "uris": [
              {
                "scheme": "file",                         // 文档要求本地 file
                "type": "com.ou.hm.wordtree.ebook",       // 与 utd.json5 中 TypeId 一致（自定义 .wte）
                "linkFeature": "FileOpen"                 // 必选，首字母大写
              },
              {
                "scheme": "content",                      // 应用间常见 content 授权 URI
                "type": "com.ou.hm.wordtree.ebook",       // 同上 type
                "linkFeature": "FileOpen"                 // 必选，首字母大写
              },
              {
                "scheme": "file",                         // 文档要求本地 file
                "type": "general.zip-archive",            // 与 utd BelongingToTypes、包格式一致
                "linkFeature": "FileOpen"                 // 必选，首字母大写
              },
              {
                "scheme": "content",                      // 应用间常见 content 授权 URI
                "type": "general.zip-archive",            // 同上 type
                "linkFeature": "FileOpen"                 // 必选，首字母大写
              },
              {
                "scheme": "file",                         // 文档要求本地 file
                "type": "application/vnd.wordtree.ebook", // 与 utd.json5 中 MIMETypes 一致
                "linkFeature": "FileOpen"                 // 必选，首字母大写
              },
              {
                "scheme": "content",                      // 应用间常见 content 授权 URI
                "type": "application/vnd.wordtree.ebook", // 同上 type
                "linkFeature": "FileOpen"                 // 必选，首字母大写
              },
              {
                "scheme": "file",                         // 文档要求本地 file
                "type": "application/x-wte",              // 与 utd.json5 中 MIMETypes 一致
                "linkFeature": "FileOpen"                 // 必选，首字母大写
              },
              {
                "scheme": "content",                      // 应用间常见 content 授权 URI
                "type": "application/x-wte",              // 同上 type
                "linkFeature": "FileOpen"                 // 必选，首字母大写
              },
              {
                "scheme": "file",                         // 文档要求本地 file
                "type": "application/zip",                // 调用方只标 zip MIME 时
                "linkFeature": "FileOpen"                 // 必选，首字母大写
              },
              {
                "scheme": "content",                      // 应用间常见 content 授权 URI
                "type": "application/zip",                // 同上 type
                "linkFeature": "FileOpen"                 // 必选，首字母大写
              },
              {
                "scheme": "file",                         // 文档要求本地 file
                "type": "application/octet-stream",       // 调用方未给细分类时的兜底
                "linkFeature": "FileOpen"                 // 必选，首字母大写
              },
              {
                "scheme": "content",                      // 应用间常见 content 授权 URI
                "type": "application/octet-stream",       // 同上 type
                "linkFeature": "FileOpen"                 // 必选，首字母大写
              }
            ]
          }
        ]
      }
    ],
    "extensionAbilities": [
      {
        "name": "EntryBackupAbility",
        "srcEntry": "./ets/entrybackupability/EntryBackupAbility.ets",
        "type": "backup",
        "exported": false,
        "metadata": [
          {
            "name": "ohos.extension.backup",
            "resource": "$profile:backup_config"
          }
        ],
      }
    ],
    "metadata": [ // 配置信息如下
      {
        "name": "client_id",
        "value": "6917592474741463583"//单词树 华为登录用， OAuth 2.0客户端ID（凭据），也是AppID
      }
    ],
    "querySchemes": [
      "weixin",                                      // 微信（登录 / 系统分享目标可见性需声明）
      "wxopensdk",                                   // 微信 SDK
      "https",                                       // QQ 登录、通用链接
      "qqopenapi"                                    // QQ 互联
    ]
  }
}