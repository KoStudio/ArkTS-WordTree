{
  "module": {
    "name": "entry",
    "type": "entry",
    "description": "$string:module_desc",
    "mainElement": "EntryAbility",
    "deviceTypes": [
      "phone"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
    "requestPermissions": [
      {
        "name": "ohos.permission.VIBRATE", //震动
        //"reason": "$string:review_cfm_btn_review_all"
      },
      {
        "name": "ohos.permission.GET_NETWORK_INFO" //网络状态
      },
      {
        "name": "ohos.permission.INTERNET", // 权限名称 访问网络
        //        "reason": "$string:init_tab_create", // 可选：权限申请理由（用户授权权限需填写）
        //        "usedScene": {                       // 可选：权限使用场景
        //          "abilities": ["MainAbility"],      // 使用权限的Ability列表
        //          "when": "inuse"                    // 使用时机（inuse/always）
        //        },
      },
      {
        "name": "ohos.permission.GET_BUNDLE_INFO"  //获取应用版本信息
      },

      {
        "name": "ohos.permission.PUBLISH_AGENT_REMINDER",
        "reason": "$string:set_msg_permission_notification", // 权限用途说明
        "usedScene": {
          "abilities": ["EntryAbility"], // 使用该权限的Ability
          "when": "always" // 使用时机
        }
      },
      //      {
      //        "name": "ohos.permission.FILE_ACCESS_PERSIST",
      //        "reason": "$string:shouxie_permit_file_save" //用于手写数据存储
      //      },
      {
        "name": "ohos.permission.MICROPHONE",
        "reason": "$string:microphone_permission_reason", ///用于语音识别
        "usedScene": {
          "abilities": ["EntryAbility"],
          "when": "inuse"
        }
      },
//      {
//        "name": "ohos.permission.READ_MEDIA",
//        "reason": "$string:image_read_permission_reason",//"需要读取相册权限"
//        "usedScene": {
//          "abilities": ["EntryAbility"], // 使用该权限的Ability
//          "when": "inuse" // 使用时机
//        }
//      },
//      {
//        "name": "ohos.permission.WRITE_MEDIA",
//        "reason": "$string:image_write_permission_reason",//保存字卡到相册
//        "usedScene": {
//          "abilities": ["EntryAbility"], // 使用该权限的Ability
//          "when": "inuse" // 使用时机
//        }
//      },
//      {
//        "name": "ohos.permission.CAMERA",
//        "reason": "$string:camera_permission_reason", //使用相机扫描字卡
//        "usedScene": {
//          "abilities": ["EntryAbility"], // 使用该权限的Ability
//          "when": "inuse" // 使用时机
//        }
//      },
//      {
//        "name":"ohos.permission.PRINT", //打印
//      },
      //      {
      //        "name": "ohos.permission.APP_TRACKING_CONSENT",
      //        "reason": "$string:reason",
      //        "usedScene": {}
      //      }


    ],
    "abilities": [
      {
        "name": "EntryAbility",
        "srcEntry": "./ets/entryability/EntryAbility.ets",
        "description": "$string:EntryAbility_desc",
        "icon": "$media:layered_image",
        "label": "$string:app_name",
        "startWindowIcon": "$media:startIcon",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        "skills": [
          {
            // 桌面入口 + QQ（与下方「打开文件」分 skill，避免本段 domainVerify 影响 file/content 的 Want）
            "entities": [
              "entity.system.home",
              "entity.system.browsable"                  // QQ 登录、Deep Link
            ],
            "actions": [
              "action.system.home",
              "ohos.want.action.viewData"                // QQ 回调
            ],
            "uris": [
              {
                "scheme": "qqopenapi",
                "host": "1105391403",
                "pathRegex": "\\b(auth|share)\\b",
                "linkFeature": "Login"                 // QQ 互联；appId 须与开放平台一致
              },
              {
                "scheme": "https",
                "host": "www.dancishu.com",
                "path": "path1"                        // QQ 关联域名；path 按业务收窄
              }
            ],
            "domainVerify": true                        // AppLink 域名验证
          },
          {
            // 其他应用打开文件：action=ohos.want.action.viewData，uris 须 linkFeature=FileOpen
            // .wte 自定义 UTD：resources/rawfile/arkdata/utd/utd.json5（TypeId 与下列 type 相同）
            "actions": [
              "ohos.want.action.viewData"
            ],
            "uris": [
              {
                "scheme": "file",
                "type": "com.ou.hm.wordtree.ebook",
                "linkFeature": "FileOpen"              // 自定义类型（.wte），安装时写入系统 UTD
              },
              {
                "scheme": "content",
                "type": "com.ou.hm.wordtree.ebook",
                "linkFeature": "FileOpen"              // 常见沙箱/微信等 content URI
              },
              {
                "scheme": "file",
                "type": "general.zip-archive",
                "linkFeature": "FileOpen"              // 调用方只声明 zip 时的兜底
              },
              {
                "scheme": "file",
                "type": "general.octet-stream",
                "linkFeature": "FileOpen"              // 调用方只声明二进制时的兜底
              },
              {
                "scheme": "content",
                "type": "general.zip-archive",
                "linkFeature": "FileOpen"              // content + zip 兜底
              },
              {
                "scheme": "content",
                "type": "general.octet-stream",
                "linkFeature": "FileOpen"              // content + 二进制兜底
              }
            ]
          },
          {
            // 系统分享 Sheet：sendData + entity.system.share；uri 类型与「打开文件」段对齐
            "entities": [
              "entity.system.share"
            ],
            "actions": [
              "ohos.want.action.sendData"
            ],
            "uris": [
              {
                "scheme": "file",
                "type": "com.ou.hm.wordtree.ebook",
                "linkFeature": "FileOpen"              // 自定义 .wte
              },
              {
                "scheme": "content",
                "type": "com.ou.hm.wordtree.ebook",
                "linkFeature": "FileOpen"              // 分享常见 content
              },
              {
                "scheme": "file",
                "type": "general.zip-archive",
                "linkFeature": "FileOpen"              // zip 兜底
              },
              {
                "scheme": "content",
                "type": "general.zip-archive",
                "linkFeature": "FileOpen"              // content zip 兜底
              }
            ]
          }
        ]
      }
    ],
    "extensionAbilities": [
      {
        "name": "EntryBackupAbility",
        "srcEntry": "./ets/entrybackupability/EntryBackupAbility.ets",
        "type": "backup",
        "exported": false,
        "metadata": [
          {
            "name": "ohos.extension.backup",
            "resource": "$profile:backup_config"
          }
        ],
      }
    ],
    "metadata": [ // 配置信息如下
      {
        "name": "client_id",
        "value": "6917592474741463583"//单词树 华为登录用， OAuth 2.0客户端ID（凭据），也是AppID
      }
    ],
    "querySchemes": [
//      "weixin",     //微信登录
//      "wxopensdk",  //微信登录
      "https",      //QQ登录
      "qqopenapi"   //QQ登录
    ]
  }
}